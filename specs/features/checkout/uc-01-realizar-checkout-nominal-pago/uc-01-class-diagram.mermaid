classDiagram
    class CheckoutSession {
        +string id
        +string eventId
        +List~TicketSelection~ tickets
        +int expiresAt
        +string status
        +startSession() bool
        +validateSession() bool
        +extendSession() bool
    }

    class Participant {
        +string id
        +string name
        +string email
        +string phone
        +List~CustomField~ customFields
    }

    class Ticket {
        +string id
        +string eventId
        +string name
        +decimal price
        +bool isNominal
        +TicketType type
    }

    class TicketSelection {
        +string ticketId
        +int quantity
        +Participant participant
    }

    class Order {
        +string id
        +string checkoutSessionId
        +List~TicketSelection~ items
        +decimal subtotal
        +decimal discount
        +decimal total
        +string status
        +Coupon coupon
        +createOrder() Order
        +applyDiscount(Coupon) bool
        +calculateTotal() decimal
    }

    class Payment {
        +string id
        +string orderId
        +PaymentMethod method
        +PaymentStatus status
        +string transactionId
        +decimal amount
        +processPayment() PaymentResult
        +verifyStatus() PaymentStatus
    }

    class Coupon {
        +string code
        +CouponType type
        +decimal value
        +Date expiresAt
        +bool isValid()
    }

    class Responsible {
        +string name
        +string email
        +string phone
        +bool isParticipant
    }

    class UserAccount {
        +string id
        +string email
        +string name
        +Date createdAt
        +bool isNewAccount
    }

    CheckoutSession --> TicketSelection : contains
    TicketSelection --> Participant : has
    TicketSelection --> Ticket : refers
    Order --> TicketSelection : contains
    Order --> Coupon : has
    Payment --> Order : belongs
    Responsible --> UserAccount : could be
